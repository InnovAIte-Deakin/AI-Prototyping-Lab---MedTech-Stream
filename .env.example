FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://reportx:reportx@localhost:5432/reportx
AUTH_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_SESSION_TTL_DAYS=30
# Never commit real secrets. Leave blank or set locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_BASE=https://api.openai.com/v1
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,backend,frontend
ENABLE_OCR=1
OPENAI_REASONING_EFFORT=high
OPENAI_MAX_OUTPUT_TOKENS=5000
OPENAI_TIMEOUT_S=60
OPENAI_USE_RESPONSES=0
